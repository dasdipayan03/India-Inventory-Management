GOOGLE_REDIRECT_URI=

MAIL_RELAY_URL=
MAIL_RELAY_KEY=

SUPPORT_ADMIN_EMAIL=
SUPPORT_ADMIN_PASSWORD=
SUPPORT_ADMIN_PASSWORD_HASH=
SUPPORT_ADMIN_BOOTSTRAP=false
SUPPORT_ADMIN_NAME=Developer Support

